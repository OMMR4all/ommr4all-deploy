# ── OMMR4all Docker configuration ──────────────────────────────────────────
# Copy this file to .env and edit before running docker-compose.

# ── Network ─────────────────────────────────────────────────────────────────
# Host port that maps to the container's Apache (internal port 8001).
# Access the app at http://localhost:<PORT>
PORT=8001

# ── Storage ─────────────────────────────────────────────────────────────────
# Absolute (or relative) path on the HOST where book/page data is stored.
# This directory is volume-mounted into the container; data survives rebuilds.
#
# Linux / macOS:
STORAGE=./storage
#
# Windows (use forward slashes or drive letter):
# STORAGE=C:/Users/yourname/ommr4all-storage

# ── Superuser (only used when the database is empty / first run) ─────────────
# If DJANGO_SUPERUSER_USERNAME is set, a superuser is created automatically
# on first start if none exists. Leave blank to skip (create manually instead).
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# ── LLM text transcription (text_llm step, all optional) ────────────────────
# The local Chandra 2 model (datalab-to/chandra-ocr-2) is always offered if
# transformers/torch are installed. Cloud providers are only enabled in the
# client if their API key is configured here — keys stay on the server and are
# never entered in or sent from the browser.
#
# Google Gemini:
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
#
# Any OpenAI-compatible endpoint (OpenAI, OpenRouter, or a local vLLM/LM Studio
# server — for a local server set OPENAI_API_URL, the key may stay empty):
OPENAI_API_KEY=
# OPENAI_API_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ── Submodule branches ──────────────────────────────────────────────────────
# Which git branch to use for each Python/Angular submodule.
# After changing these, run setup_branches.sh (Linux/macOS/Git Bash)
# or the equivalent git commands, then rebuild:  docker-compose up --build
SERVER_BRANCH=master
CLIENT_BRANCH=master
LINE_DETECTION_BRANCH=master
LAYOUT_ANALYSIS_BRANCH=master
